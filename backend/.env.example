DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/newscada
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003"]
DEBUG=false
LOG_LEVEL=DEBUG
LOG_FILE=logs/backend.log
LOG_DEVICE_PAYLOADS=true
IEC_CONNECT_TIMEOUT_SECONDS=5
IEC_READ_WINDOW_SECONDS=8
IEC_RECORD_COLLECTOR_ENABLED=true
IEC_RECORD_INTERVAL_SECONDS=1
IEC_RECORD_CONNECT_TIMEOUT_SECONDS=1
IEC_RECORD_READ_TIMEOUT_SECONDS=1
IEC_RECORD_IDLE_AFTER_DATA_SECONDS=0.4
IEC_RECORD_MAX_PARALLEL_POLLS=10
